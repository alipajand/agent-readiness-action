{
  "name": "agent-readiness-action",
  "version": "0.1.0",
  "description": "GitHub Action wrapper for agent-readiness-kit CI audits",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
